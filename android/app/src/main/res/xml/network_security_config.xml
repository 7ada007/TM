<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Cleartext is refused everywhere and only system CAs are trusted. User-installed
      CAs are deliberately NOT trusted, which blocks the common "install a proxy CA and
      read the traffic" interception workflow on non-rooted devices.

      To debug traffic locally, temporarily add a debug-overrides block; never ship one.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.tareeqalmajd.best</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
        <!--
          Pinning is enforced in Dart (see lib/core/security_config.dart) so that pin
          rotation ships with an app update rather than being split across two places.
          If you prefer platform-level pinning, add <pin-set> entries here as well.
        -->
    </domain-config>
</network-security-config>
