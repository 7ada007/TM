<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!--
      Android 12+ backup/transfer policy. Everything is excluded: the app holds JWTs
      and cached student data, none of which should leave the device via cloud backup
      or device-to-device transfer.
    -->
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </cloud-backup>

    <device-transfer>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
