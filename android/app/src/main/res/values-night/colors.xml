<resources>
    <color name="launch_light">#FFF5F8FD</color>
    <color name="launch_dark">#FF0A101C</color>
    <!-- Backdrop shown by LaunchTheme while the engine boots. Must match
         _SplashScreenState._backdrop in lib/features/splash/splash.dart AND
         the opening frame of assets/animations/SplashScreen.mp4, so the
         hand-off from the OS launch screen to the video is one continuous
         colour with no visible step. Theme-independent on purpose: the
         splash video is the same in light and dark. -->
    <color name="splash_backdrop">#FF003366</color>
